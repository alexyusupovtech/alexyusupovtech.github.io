---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../site";
---

<BaseLayout
  title={`Contact — ${site.name}`}
  description={`Get in touch with ${site.name} — ${site.studio}, ${site.location}.`}
>
  <section class="contact">
    <div class="wrap">
      <!-- Hero -->
      <header class="contact-hero">
        <p class="eyebrow" data-reveal>Transmission open</p>
        <h1 class="contact-title glow-text" data-reveal>Making Contact?</h1>
        <p class="contact-sub text-measure" data-reveal>
          Get in touch — I'd love to hear about your project and answer any
          questions you may have. Tell me what you're making.
        </p>
      </header>

      <div class="contact-layout">
        <!-- Form -->
        <form class="contact-form" id="contact-form" data-email={site.email} data-reveal>
          <div class="field">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" autocomplete="name" placeholder="Your name" required />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" autocomplete="email" placeholder="you@email.com" required />
          </div>
          <div class="field">
            <label for="subject">Subject <span class="req">*</span></label>
            <input type="text" id="subject" name="subject" required placeholder="What's this about?" />
          </div>
          <div class="field">
            <label for="message">Message <span class="req">*</span></label>
            <textarea id="message" name="message" rows="6" required placeholder="Tell me about your project…"></textarea>
          </div>
          <!-- spam honeypot: real people leave this empty -->
          <input type="text" name="_honey" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <button type="submit" class="btn form-submit">Send message <span class="arrow">↗</span></button>
          <p class="form-status mono" data-form-status hidden></p>
        </form>

        <!-- Get in touch -->
        <aside class="contact-info">
          <div class="info-block" data-reveal>
            <p class="info-label mono">Email</p>
            <a href={`mailto:${site.email}`} class="info-email link-line">{site.email}</a>
          </div>
          <div class="info-block" data-reveal>
            <p class="info-label mono">Studio</p>
            <p class="info-val">{site.studio}</p>
            <p class="info-val muted">{site.location}</p>
          </div>
          <div class="info-block" data-reveal>
            <p class="info-label mono">Elsewhere</p>
            <ul class="info-socials">
              {site.socials.map((s) => (
                <li>
                  <a href={s.url} class="link-line" target="_blank" rel="noopener">
                    {s.label} <span class="muted">{s.handle}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>("#contact-form");
  const statusEl = document.querySelector<HTMLElement>("[data-form-status]");
  const btn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
  const email = form?.dataset.email || "";

  const setStatus = (msg: string, kind: "" | "ok" | "err" = "") => {
    if (!statusEl) return;
    statusEl.hidden = false;
    statusEl.textContent = msg;
    statusEl.className = "form-status mono" + (kind ? " is-" + kind : "");
  };

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;

    const data = Object.fromEntries(new FormData(form).entries()) as Record<string, string>;
    // Formsubmit control fields
    data._subject = `Portfolio message: ${data.subject || "(no subject)"}`;
    data._template = "table";
    data._captcha = "false";

    setStatus("Sending…");
    if (btn) btn.disabled = true;

    try {
      const res = await fetch(`https://formsubmit.co/ajax/${encodeURIComponent(email)}`, {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify(data),
      });
      const json = await res.json().catch(() => ({}));
      if (res.ok && String(json.success) !== "false") {
        setStatus("✓ Message sent — thank you! I'll get back to you soon.", "ok");
        form.reset();
      } else {
        throw new Error(json.message || "Request failed");
      }
    } catch (err) {
      setStatus(`Couldn't send just now — please email me directly at ${email}.`, "err");
    } finally {
      if (btn) btn.disabled = false;
    }
  });
</script>

<style>
  .contact { padding-top: clamp(9rem, 16vw, 13rem); padding-bottom: clamp(4rem, 9vw, 8rem); }

  .contact-hero { margin-bottom: clamp(2.5rem, 6vw, 4.5rem); }
  .contact-title {
    /* same scale as the gallery page titles (caps at step-4's 5.5rem),
       but on one line — scales down on small screens so it never wraps */
    font-size: clamp(2rem, 8.5vw, 5.5rem);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 1.2rem 0 1.3rem;
  }
  .contact-sub { font-size: var(--step-1); color: var(--text-soft); font-weight: 300; }

  .contact-layout {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: start;
  }

  /* Form */
  .contact-form { display: grid; gap: 1.4rem; }
  .field { display: grid; gap: 0.5rem; }
  .field label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-soft);
  }
  .req { color: var(--accent); }
  .field input,
  .field textarea {
    font-family: var(--font-sans);
    font-size: var(--step-0);
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 13%, var(--bg)); /* dark gold */
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line-strong));
    border-radius: 10px;
    padding: 0.9em 1em;
    width: 100%;
    resize: vertical;
    transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease), background 0.3s var(--ease);
  }
  .field input::placeholder,
  .field textarea::placeholder { color: color-mix(in srgb, var(--accent-ink) 55%, transparent); }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 20%, var(--bg)); /* richer gold on focus */
    box-shadow: 0 0 0 3px rgba(var(--accent-rgb),0.18), 0 0 22px rgba(var(--accent-rgb),0.14);
  }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .form-submit { justify-self: start; margin-top: 0.4rem; }
  .form-status { font-size: var(--step--1); letter-spacing: 0.02em; color: var(--text-soft); }
  .form-status.is-ok { color: var(--accent-3); }
  .form-status.is-err { color: #ff9a86; }

  /* Info */
  .contact-info { display: grid; gap: 2rem; }
  .info-block { padding-bottom: 2rem; border-bottom: 1px solid var(--line); }
  .info-block:last-child { border-bottom: none; padding-bottom: 0; }
  .info-label {
    font-size: var(--step--1);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-3);
    margin-bottom: 0.9rem;
  }
  .info-email { font-family: var(--font-display); font-size: var(--step-1); color: var(--accent-ink); word-break: break-word; }
  .info-val { margin: 0 0 0.3rem; }
  .info-socials { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; }

  @media (max-width: 820px) {
    .contact-layout { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>
